# ============================================================================
# PROFILE TESTS - Standalone Performance Benchmarking Binaries
# ============================================================================
# Profile tests are NOT unit tests - they're standalone binaries for benchmarking
# performance of specific functions/modules. They don't use doctest and produce
# structured output for AI-driven profile-guided optimization.
#
# Usage:
#   bash profile <function> --docker --iterations 20
#
# Generated by: ci/profile/generate_profile_test.py

# Discover all profile test files (profile_*.cpp)
profile_test_files = run_command(
  'python', '-c',
  '''
import glob
import os
import sys
# Use source directory passed as argument
source_dir = sys.argv[1] if len(sys.argv) > 1 else "."
top = set(glob.glob(os.path.join(source_dir, "tests/profile/*.cpp")))
files = sorted(top | set(glob.glob(os.path.join(source_dir, "tests/profile/**/*.cpp"), recursive=True)))
if files:
    # Use semicolon as separator to avoid newline issues on Windows
    print(";".join(files))
  ''',
  meson.project_source_root(),
  check: false
).stdout().strip()

if profile_test_files != ''
  # Add system libraries needed by crash handler (dbghelp, psapi on Windows)
  profile_link_args = unit_test_link_args
  if host_machine.system() == 'windows'
    profile_link_args += ['-ldbghelp', '-lpsapi']
  endif

  foreach profile_file : profile_test_files.split(';')
    # Extract test name from file path: json_memory_profile.cpp → json_memory_profile
    # Supports both old (profile_*.cpp) and new naming conventions
    profile_basename = fs.name(profile_file)  # e.g., json_memory_profile.cpp or profile_sincos32.cpp
    profile_name = profile_basename.substring(0, -4)  # Remove '.cpp' extension

    # Build as standalone executable (no PCH, no doctest, no runner)
    # Uses profile_test_compile_args for readable stack traces (frame pointers + debug symbols)
    # NOTE (#2328): includes passed via cpp_args (abs forward-slash) to avoid
    # backslash + relative -I propagation from include_directories() on Windows.
    executable(profile_name,
      profile_file,
      cpp_args: profile_test_compile_args + [path_norm_I_root, path_norm_I_src, path_norm_I_stub],
      link_args: profile_link_args,
      link_with: [fastled_lib, crash_handler_lib],
      install: false,
      build_by_default: false  # Only build when explicitly requested via 'bash profile <function>'
    )
  endforeach

  message('Profile tests found: ' + profile_test_files.split(';').length().to_string() + ' benchmarks')
else
  message('No profile tests found (tests/profile/*.cpp)')
endif
